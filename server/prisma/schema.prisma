generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SADMIN
  QC_EXEC
  QC_MGR
  QA_EXEC
  QA_MGR
  MKT_EXEC
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum DeptName {
  QC
  QA
  MARKETING
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum MasterStatus {
  DRAFT
  SUBMITTED
  QC_APPROVED
  QA_SIGNED
  SUPERSEDED
}

enum ResultType {
  QUALITATIVE
  QUANTITATIVE
}

enum Operator {
  NMT
  NLT
  BETWEEN
}

enum VariantType {
  GENERAL
  CUSTOMER
}

enum TemplateStatus {
  DRAFT
  SUBMITTED
  QC_APPROVED
  QA_SIGNED
  SUPERSEDED
}

enum DocType {
  SPEC
  MOA
  AWS
  COA
}

enum DocStatus {
  PENDING
  DRAFT
  SUBMITTED
  QC_APPROVED
  QA_SIGNED
  REJECTED
  AUTO_GENERATED
  ISSUED
}

enum DocPhase {
  SPEC
  MOA
  AWS
  COA
  RELEASED
}

enum BatchStatus {
  ACTIVE
  RELEASED
  ABANDONED
}

enum CoaComplianceVerdict {
  COMPLIES
  DOES_NOT_COMPLY
}

enum SectionStatus {
  NOT_STARTED
  IN_PROGRESS
  AWAITING_CHECK
  COMPLETED
}

enum Conclusion {
  SATISFACTORY
  NOT_SATISFACTORY
  PASS
  FAIL
}

enum InstrumentStatus {
  ACTIVE
  UNDER_MAINTENANCE
  RETIRED
}

enum ReagentStatus {
  ACTIVE
  EXPIRED
  DISPOSED
}

enum CCClassification {
  CRITICAL
  MAJOR
  MINOR
}

enum CCStatus {
  REQUESTED
  ACCEPTED
  IMPACT_ASSESSMENT
  APPROVED
  IMPLEMENTING
  EXTENDED
  VERIFICATION
  CLOSED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id             String     @id @default(uuid()) @db.Uuid
  fullName       String     @map("full_name")
  username       String     @unique
  email          String     @unique
  passwordHash   String     @map("password_hash")
  role           Role
  departmentId   String?    @map("department_id") @db.Uuid
  status         UserStatus @default(ACTIVE)
  forcePwdChange Boolean    @default(true) @map("force_pwd_change")
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz
  failedAttempts Int        @default(0) @map("failed_attempts")
  lockedUntil    DateTime?  @map("locked_until") @db.Timestamptz
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz

  department Department? @relation(fields: [departmentId], references: [id])

  productsCreated            Product[]                   @relation("ProductCreatedBy")
  productMastersCreated      ProductMaster[]             @relation("PmCreatedBy")
  productMastersSubmitted    ProductMaster[]             @relation("PmSubmittedBy")
  productMastersQcApproved   ProductMaster[]             @relation("PmQcApprovedBy")
  productMastersQaSigned     ProductMaster[]             @relation("PmQaSignedBy")
  specTemplatesCreated       SpecTemplate[]              @relation("StCreatedBy")
  specTemplatesSubmitted     SpecTemplate[]              @relation("StSubmittedBy")
  specTemplatesQcApproved    SpecTemplate[]              @relation("StQcApprovedBy")
  specTemplatesQaSigned      SpecTemplate[]              @relation("StQaSignedBy")
  batchesAssigned            Batch[]                     @relation("BatchAssignedQc")
  batchesCreated             Batch[]                     @relation("BatchCreatedBy")
  batchDocumentsCreated      BatchDocument[]             @relation("BdCreatedBy")
  batchDocumentsSubmitted    BatchDocument[]             @relation("BdSubmittedBy")
  batchDocumentsQcApproved   BatchDocument[]             @relation("BdQcApprovedBy")
  batchDocumentsQaSigned     BatchDocument[]             @relation("BdQaSignedBy")
  batchDocumentsRejected     BatchDocument[]             @relation("BdRejectedBy")
  awsSectionsAnalyzed        AwsSection[]                @relation("AwsAnalyzedBy")
  awsSectionsChecked         AwsSection[]                @relation("AwsCheckedBy")
  fileAttachmentsUploaded    FileAttachment[]            @relation("FileUploadedBy")
  changeControlsInitiated    ChangeControl[]             @relation("CcInitiatedBy")
  changeControlNotifications ChangeControlNotification[] @relation("CcnNotifiedUser")
  notifications              Notification[]              @relation("NotificationUser")
  sessions                   Session[]                   @relation("SessionUser")

  @@map("users")
}

model Department {
  id          String   @id @default(uuid()) @db.Uuid
  name        DeptName @unique
  colorHex    String?  @map("color_hex")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  users                      User[]
  testParameters             TestParameter[]
  specDocumentTests          SpecDocumentTest[]          @relation("SpecDocTestDepartment")
  instruments                Instrument[]
  reagents                   Reagent[]
  changeControlsInitiated    ChangeControl[]
  changeControlNotifications ChangeControlNotification[]

  @@map("departments")
}

model Product {
  id                 String        @id @default(uuid()) @db.Uuid
  name               String
  code               String        @unique @db.VarChar(10)
  chemicalName       String?       @map("chemical_name")
  chemicalFormula    String?       @map("chemical_formula")
  molecularWeight    Decimal?      @map("molecular_weight")
  molecularWeightUom String?       @map("molecular_weight_uom")
  regulatoryRefs     String[]      @map("regulatory_refs")
  originSource       String?       @map("origin_source")
  shelfLifeMonths    Int           @map("shelf_life_months")
  storageConditions  String?       @map("storage_conditions")
  status             ProductStatus
  createdById        String        @map("created_by") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  createdBy      User            @relation("ProductCreatedBy", fields: [createdById], references: [id])
  productMasters ProductMaster[]
  specTemplates  SpecTemplate[]
  batches        Batch[]

  @@map("products")
}

model ProductMaster {
  id               String       @id @default(uuid()) @db.Uuid
  productId        String       @map("product_id") @db.Uuid
  revisionNo       Int          @map("revision_no")
  status           MasterStatus
  effectiveDate    DateTime?    @map("effective_date") @db.Date
  supersedesId     String?      @map("supersedes_id") @db.Uuid
  createdById      String       @map("created_by") @db.Uuid
  submittedById    String?      @map("submitted_by") @db.Uuid
  submittedAt      DateTime?    @map("submitted_at") @db.Timestamptz
  qcApprovedById   String?      @map("qc_approved_by") @db.Uuid
  qcApprovedAt     DateTime?    @map("qc_approved_at") @db.Timestamptz
  qaSignedById     String?      @map("qa_signed_by") @db.Uuid
  qaSignedAt       DateTime?    @map("qa_signed_at") @db.Timestamptz
  rejectionComment String?      @map("rejection_comment")
  importedFrom     String?      @map("imported_from")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  product        Product         @relation(fields: [productId], references: [id])
  supersedes     ProductMaster?  @relation("ProductMasterSupersedes", fields: [supersedesId], references: [id])
  supersededBy   ProductMaster[] @relation("ProductMasterSupersedes")
  createdBy      User            @relation("PmCreatedBy", fields: [createdById], references: [id])
  submittedBy    User?           @relation("PmSubmittedBy", fields: [submittedById], references: [id])
  qcApprovedBy   User?           @relation("PmQcApprovedBy", fields: [qcApprovedById], references: [id])
  qaSignedBy     User?           @relation("PmQaSignedBy", fields: [qaSignedById], references: [id])
  testParameters TestParameter[]
  moaSections    MoaSection[]
  specTemplates  SpecTemplate[]
  batchDocuments BatchDocument[]
  batches        Batch[]

  @@map("product_masters")
}

model TestParameter {
  id                  String     @id @default(uuid()) @db.Uuid
  productMasterId     String     @map("product_master_id") @db.Uuid
  sortOrder           Int        @map("sort_order")
  testName            String     @map("test_name")
  isMandatory         Boolean    @map("is_mandatory")
  resultType          ResultType @map("result_type")
  acceptanceCriteria  String?    @map("acceptance_criteria")
  minValue            Decimal?   @map("min_value")
  maxValue            Decimal?   @map("max_value")
  operator            Operator?
  uom                 String?
  departmentId        String?    @map("department_id") @db.Uuid
  isOutsideLab        Boolean    @default(false) @map("is_outside_lab")
  calculationFormula  String?    @map("calculation_formula")
  formulaVariables    Json?      @map("formula_variables")
  instrumentsRequired String[]   @map("instruments_required")
  reagentsRequired    String[]   @map("reagents_required")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz

  productMaster       ProductMaster        @relation(fields: [productMasterId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id])
  moaSections         MoaSection[]
  specTemplateTests   SpecTemplateTest[]
  specDocumentTests   SpecDocumentTest[]   @relation("SpecDocTestParameter")
  moaDocumentSections MoaDocumentSection[] @relation("MoaDocTestParameter")
  awsSections         AwsSection[]

  @@map("test_parameters")
}

model MoaSection {
  id                  String   @id @default(uuid()) @db.Uuid
  productMasterId     String   @map("product_master_id") @db.Uuid
  testParameterId     String   @map("test_parameter_id") @db.Uuid
  pharmacopoeia       String?
  samplePreparation   String?  @map("sample_preparation")
  standardPreparation String?  @map("standard_preparation")
  blankPreparation    String?  @map("blank_preparation")
  conclusionTemplate  String?  @map("conclusion_template")
  additionalNotes     String?  @map("additional_notes")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  productMaster ProductMaster @relation(fields: [productMasterId], references: [id])
  testParameter TestParameter @relation(fields: [testParameterId], references: [id])

  @@map("moa_sections")
}

model SpecTemplate {
  id                   String         @id @default(uuid()) @db.Uuid
  productId            String         @map("product_id") @db.Uuid
  sourceMasterId       String         @map("source_master_id") @db.Uuid
  templateNo           String         @unique @map("template_no")
  variantType          VariantType    @map("variant_type")
  customerName         String?        @map("customer_name")
  copiedFromTemplateId String?        @map("copied_from_template_id") @db.Uuid
  revisionNo           Int            @map("revision_no")
  status               TemplateStatus
  effectiveDate        DateTime?      @map("effective_date") @db.Date
  supersedesId         String?        @map("supersedes_id") @db.Uuid
  createdById          String         @map("created_by") @db.Uuid
  submittedById        String?        @map("submitted_by") @db.Uuid
  submittedAt          DateTime?      @map("submitted_at") @db.Timestamptz
  qcApprovedById       String?        @map("qc_approved_by") @db.Uuid
  qcApprovedAt         DateTime?      @map("qc_approved_at") @db.Timestamptz
  qaSignedById         String?        @map("qa_signed_by") @db.Uuid
  qaSignedAt           DateTime?      @map("qa_signed_at") @db.Timestamptz
  rejectionComment     String?        @map("rejection_comment")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  product            Product            @relation(fields: [productId], references: [id])
  sourceMaster       ProductMaster      @relation(fields: [sourceMasterId], references: [id])
  copiedFromTemplate SpecTemplate?      @relation("SpecTemplateCopy", fields: [copiedFromTemplateId], references: [id])
  copiesOfTemplate   SpecTemplate[]     @relation("SpecTemplateCopy")
  supersedes         SpecTemplate?      @relation("SpecTemplateSupersedes", fields: [supersedesId], references: [id])
  supersededBy       SpecTemplate[]     @relation("SpecTemplateSupersedes")
  createdBy          User               @relation("StCreatedBy", fields: [createdById], references: [id])
  submittedBy        User?              @relation("StSubmittedBy", fields: [submittedById], references: [id])
  qcApprovedBy       User?              @relation("StQcApprovedBy", fields: [qcApprovedById], references: [id])
  qaSignedBy         User?              @relation("StQaSignedBy", fields: [qaSignedById], references: [id])
  specTemplateTests  SpecTemplateTest[]
  batches            Batch[]
  batchDocuments     BatchDocument[]

  @@index([productId, variantType, status])
  @@map("spec_templates")
}

model SpecTemplateTest {
  id                 String   @id @default(uuid()) @db.Uuid
  specTemplateId     String   @map("spec_template_id") @db.Uuid
  testParameterId    String   @map("test_parameter_id") @db.Uuid
  sortOrder          Int      @map("sort_order")
  isIncluded         Boolean  @default(true) @map("is_included")
  isOptional         Boolean  @default(false) @map("is_optional")
  overrideMinValue   Decimal? @map("override_min_value")
  overrideMaxValue   Decimal? @map("override_max_value")
  overrideAcceptance String?  @map("override_acceptance")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  specTemplate  SpecTemplate  @relation(fields: [specTemplateId], references: [id])
  testParameter TestParameter @relation(fields: [testParameterId], references: [id])

  @@map("spec_template_tests")
}

model Batch {
  id                          String      @id @default(uuid()) @db.Uuid
  productId                   String      @map("product_id") @db.Uuid
  productMasterId             String      @map("product_master_id") @db.Uuid
  specTemplateId              String      @map("spec_template_id") @db.Uuid
  batchNo                     String      @unique @map("batch_no")
  arn                         String      @unique
  mfgDateMonth                Int         @map("mfg_date_month")
  mfgDateYear                 Int         @map("mfg_date_year")
  expiryDate                  DateTime    @map("expiry_date") @db.Date
  batchSize                   Decimal?    @map("batch_size")
  batchSizeUom                String?     @map("batch_size_uom")
  qtySampled                  Decimal?    @map("qty_sampled")
  qtySampledUom               String?     @map("qty_sampled_uom")
  customerName                String?     @map("customer_name")
  customerRef                 String?     @map("customer_ref")
  customerSpecialInstructions String?     @map("customer_special_instructions")
  currentDocPhase             DocPhase    @map("current_doc_phase")
  status                      BatchStatus
  assignedQcExecId            String?     @map("assigned_qc_exec_id") @db.Uuid
  createdById                 String      @map("created_by") @db.Uuid
  createdAt                   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  releasedAt                  DateTime?   @map("released_at") @db.Timestamptz
  updatedAt                   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  product        Product         @relation(fields: [productId], references: [id])
  productMaster  ProductMaster   @relation(fields: [productMasterId], references: [id])
  specTemplate   SpecTemplate    @relation(fields: [specTemplateId], references: [id])
  assignedQcExec User?           @relation("BatchAssignedQc", fields: [assignedQcExecId], references: [id])
  createdBy      User            @relation("BatchCreatedBy", fields: [createdById], references: [id])
  batchDocuments BatchDocument[]

  @@index([productId, status])
  @@map("batches")
}

model BatchDocument {
  id                     String    @id @default(uuid()) @db.Uuid
  batchId                String    @map("batch_id") @db.Uuid
  docType                DocType   @map("doc_type")
  docNo                  String    @map("doc_no")
  status                 DocStatus
  sourceTemplateId       String?   @map("source_template_id") @db.Uuid
  sourceMasterId         String?   @map("source_master_id") @db.Uuid
  optionalTestsActivated String[]  @map("optional_tests_activated")
  createdById            String?   @map("created_by") @db.Uuid
  submittedById          String?   @map("submitted_by") @db.Uuid
  submittedAt            DateTime? @map("submitted_at") @db.Timestamptz
  qcApprovedById         String?   @map("qc_approved_by") @db.Uuid
  qcApprovedAt           DateTime? @map("qc_approved_at") @db.Timestamptz
  qaSignedById           String?   @map("qa_signed_by") @db.Uuid
  qaSignedAt             DateTime? @map("qa_signed_at") @db.Timestamptz
  rejectionComment       String?   @map("rejection_comment")
  rejectedById           String?   @map("rejected_by") @db.Uuid
  rejectedAt             DateTime? @map("rejected_at") @db.Timestamptz
  complianceVerdict      CoaComplianceVerdict? @map("compliance_verdict")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  batch               Batch                @relation(fields: [batchId], references: [id])
  sourceTemplate      SpecTemplate?        @relation(fields: [sourceTemplateId], references: [id])
  sourceMaster        ProductMaster?       @relation(fields: [sourceMasterId], references: [id])
  createdBy           User?                @relation("BdCreatedBy", fields: [createdById], references: [id])
  submittedBy         User?                @relation("BdSubmittedBy", fields: [submittedById], references: [id])
  qcApprovedBy        User?                @relation("BdQcApprovedBy", fields: [qcApprovedById], references: [id])
  qaSignedBy          User?                @relation("BdQaSignedBy", fields: [qaSignedById], references: [id])
  rejectedBy          User?                @relation("BdRejectedBy", fields: [rejectedById], references: [id])
  awsSections         AwsSection[]
  coaResults          CoaResult[]
  specDocumentTests   SpecDocumentTest[]   @relation("SpecDocTests")
  moaDocumentSections MoaDocumentSection[] @relation("MoaDocSections")

  @@index([batchId, docType])
  @@index([status, docType])
  @@map("batch_documents")
}

model SpecDocumentTest {
  id                  String     @id @default(uuid()) @db.Uuid
  batchDocumentId     String     @map("batch_document_id") @db.Uuid
  testParameterId     String     @map("test_parameter_id") @db.Uuid
  sortOrder           Int        @map("sort_order")
  testName            String     @map("test_name") @db.VarChar(200)
  isMandatory         Boolean    @map("is_mandatory")
  isOptionalActivated Boolean    @default(false) @map("is_optional_activated")
  resultType          ResultType @map("result_type")
  acceptanceCriteria  String?    @map("acceptance_criteria")
  minValue            Decimal?   @map("min_value") @db.Decimal(15, 6)
  maxValue            Decimal?   @map("max_value") @db.Decimal(15, 6)
  operator            Operator?
  uom                 String?    @db.VarChar(30)
  departmentId        String?    @map("department_id") @db.Uuid
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz

  batchDocument BatchDocument @relation("SpecDocTests", fields: [batchDocumentId], references: [id])
  testParameter TestParameter @relation("SpecDocTestParameter", fields: [testParameterId], references: [id])
  department    Department?   @relation("SpecDocTestDepartment", fields: [departmentId], references: [id])
  awsSections   AwsSection[]

  @@index([batchDocumentId])
  @@index([testParameterId])
  @@map("spec_document_tests")
}

model MoaDocumentSection {
  id                  String   @id @default(uuid()) @db.Uuid
  batchDocumentId     String   @map("batch_document_id") @db.Uuid
  testParameterId     String   @map("test_parameter_id") @db.Uuid
  sortOrder           Int      @map("sort_order")
  testName            String   @map("test_name") @db.VarChar(200)
  pharmacopoeia       String?  @db.VarChar(50)
  samplePreparation   String?  @map("sample_preparation")
  standardPreparation String?  @map("standard_preparation")
  blankPreparation    String?  @map("blank_preparation")
  conclusionTemplate  String?  @map("conclusion_template")
  additionalNotes     String?  @map("additional_notes")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  batchDocument BatchDocument @relation("MoaDocSections", fields: [batchDocumentId], references: [id])
  testParameter TestParameter @relation("MoaDocTestParameter", fields: [testParameterId], references: [id])

  @@index([batchDocumentId])
  @@index([testParameterId])
  @@map("moa_document_sections")
}

model AwsSection {
  id                   String        @id @default(uuid()) @db.Uuid
  batchDocumentId      String        @map("batch_document_id") @db.Uuid
  testParameterId      String        @map("test_parameter_id") @db.Uuid
  specDocumentTestId   String?       @map("spec_document_test_id") @db.Uuid
  sortOrder            Int           @map("sort_order")
  status               SectionStatus
  instrumentId         String?       @map("instrument_id") @db.Uuid
  instrumentExpiredAck Boolean       @default(false) @map("instrument_expired_ack")
  reagentsUsed         Json?         @map("reagents_used")
  observations         Json?
  analyzedById         String?       @map("analyzed_by") @db.Uuid
  checkedById          String?       @map("checked_by") @db.Uuid
  calculatedResult     Decimal?      @map("calculated_result")
  resultDisplay        String?       @map("result_display")
  conclusion           Conclusion?
  oosDetected          Boolean       @default(false) @map("oos_detected")
  oosAcknowledged      Boolean       @default(false) @map("oos_acknowledged")
  oosAcknowledgedAt    DateTime?     @map("oos_acknowledged_at") @db.Timestamptz
  remarks              String?
  completedAt          DateTime?     @map("completed_at") @db.Timestamptz
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  batchDocument    BatchDocument     @relation(fields: [batchDocumentId], references: [id])
  testParameter    TestParameter     @relation(fields: [testParameterId], references: [id])
  specDocumentTest SpecDocumentTest? @relation(fields: [specDocumentTestId], references: [id])
  instrument       Instrument?       @relation(fields: [instrumentId], references: [id])
  analyzedBy      User?            @relation("AwsAnalyzedBy", fields: [analyzedById], references: [id])
  checkedBy       User?            @relation("AwsCheckedBy", fields: [checkedById], references: [id])
  fileAttachments FileAttachment[]

  @@index([batchDocumentId])
  @@index([specDocumentTestId])
  @@map("aws_sections")
}

model CoaResult {
  id               String   @id @default(uuid()) @db.Uuid
  batchDocumentId  String   @map("batch_document_id") @db.Uuid
  testName         String   @map("test_name")
  result           String
  acceptanceLimits String   @map("acceptance_limits")
  conclusion       String
  sortOrder        Int      @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  batchDocument BatchDocument @relation(fields: [batchDocumentId], references: [id])

  @@map("coa_results")
}

model FileAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  awsSectionId String   @map("aws_section_id") @db.Uuid
  fileName     String   @map("file_name")
  filePath     String   @map("file_path")
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type")
  uploadedById String   @map("uploaded_by") @db.Uuid
  uploadedAt   DateTime @map("uploaded_at") @db.Timestamptz

  awsSection AwsSection @relation(fields: [awsSectionId], references: [id])
  uploadedBy User       @relation("FileUploadedBy", fields: [uploadedById], references: [id])

  @@map("file_attachments")
}

model Instrument {
  id              String           @id @default(uuid()) @db.Uuid
  instrumentCode  String           @unique @map("instrument_code")
  name            String
  departmentId    String           @map("department_id") @db.Uuid
  calibrationDate DateTime?        @map("calibration_date") @db.Date
  useBeforeDate   DateTime?        @map("use_before_date") @db.Date
  status          InstrumentStatus
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  department  Department   @relation(fields: [departmentId], references: [id])
  awsSections AwsSection[]

  @@map("instruments")
}

model Reagent {
  id              String        @id @default(uuid()) @db.Uuid
  name            String
  lotNo           String        @map("lot_no")
  concentration   String?
  preparationDate DateTime?     @map("preparation_date") @db.Date
  expiryDate      DateTime      @map("expiry_date") @db.Date
  supplier        String?
  departmentId    String        @map("department_id") @db.Uuid
  status          ReagentStatus
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  department Department @relation(fields: [departmentId], references: [id])

  @@map("reagents")
}

model ChangeControl {
  id                 String            @id @default(uuid()) @db.Uuid
  ccNo               String            @unique @map("cc_no")
  title              String
  initiatedById      String            @map("initiated_by") @db.Uuid
  initiatingDeptId   String            @map("initiating_dept_id") @db.Uuid
  currentState       String?           @map("current_state")
  proposedState      String?           @map("proposed_state")
  classification     CCClassification?
  status             CCStatus
  riskAssessment     String?           @map("risk_assessment")
  acceptedBy         String?           @map("accepted_by") @db.Uuid
  acceptedAt         DateTime?         @map("accepted_at") @db.Timestamptz
  approvedBy         String?           @map("approved_by") @db.Uuid
  approvedAt         DateTime?         @map("approved_at") @db.Timestamptz
  targetImplDate     DateTime?         @map("target_impl_date") @db.Date
  implementedAt      DateTime?         @map("implemented_at") @db.Timestamptz
  extensionReason    String?           @map("extension_reason")
  verifiedBy         String?           @map("verified_by") @db.Uuid
  verifiedAt         DateTime?         @map("verified_at") @db.Timestamptz
  closedBy           String?           @map("closed_by") @db.Uuid
  closedAt           DateTime?         @map("closed_at") @db.Timestamptz
  cancellationReason String?           @map("cancellation_reason")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  initiatedBy    User                        @relation("CcInitiatedBy", fields: [initiatedById], references: [id])
  initiatingDept Department                  @relation(fields: [initiatingDeptId], references: [id])
  notifications  ChangeControlNotification[]

  @@index([status, classification])
  @@map("change_controls")
}

model ChangeControlNotification {
  id               String    @id @default(uuid()) @db.Uuid
  changeControlId  String    @map("change_control_id") @db.Uuid
  notifiedDeptId   String    @map("notified_dept_id") @db.Uuid
  notifiedUserId   String?   @map("notified_user_id") @db.Uuid
  notificationType String    @map("notification_type")
  isCustomerFacing Boolean   @default(false) @map("is_customer_facing")
  acknowledged     Boolean   @default(false)
  acknowledgedAt   DateTime? @map("acknowledged_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  changeControl ChangeControl @relation(fields: [changeControlId], references: [id])
  notifiedDept  Department    @relation(fields: [notifiedDeptId], references: [id])
  notifiedUser  User?         @relation("CcnNotifiedUser", fields: [notifiedUserId], references: [id])

  @@map("change_control_notifications")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  timestamp    DateTime @db.Timestamptz
  userId       String?  @map("user_id") @db.Uuid
  userName     String?  @map("user_name")
  role         String?
  department   String?
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  docNo        String?  @map("doc_no")
  fieldChanged String?  @map("field_changed")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  comment      String?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([timestamp(sort: Desc)])
  @@index([entityType, entityId])
  @@index([userId, timestamp(sort: Desc)])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation("NotificationUser", fields: [userId], references: [id])

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation("SessionUser", fields: [userId], references: [id])

  @@map("sessions")
}

model ArnSequence {
  id            String   @id @default(uuid()) @db.Uuid
  financialYear String   @unique @map("financial_year") @db.VarChar(9)
  lastSequence  Int      @map("last_sequence")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("arn_sequences")
}
